<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suraksha Home Care | Premium Monsoon & Asset Maintenance</title>
    <style>
        :root {
            --primary: #0f172a;   /* Premium Slate Black */
            --brand: #0284c7;     /* High-Trust Monsoon Blue */
            --accent: #f97316;    /* Action Orange */
            --light-bg: #f8fafc;  /* Clean Off-White */
            --text-dark: #334155; /* Neutral Dark text */
            --success: #16a34a;   /* Value Savings Green */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background-color: var(--light-bg);
            color: var(--text-dark);
            line-height: 1.6;
        }

        header {
            background-color: white;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-container {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }

        .logo {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--brand);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .cta-header-btn {
            background-color: var(--accent);
            color: white;
            padding: 10px 18px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.9rem;
            transition: background 0.2s;
        }

        .cta-header-btn:hover {
            background-color: #ea580c;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
            color: white;
            padding: 70px 20px;
            text-align: center;
        }

        .hero-content {
            max-width: 850px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            line-height: 1.3;
        }

        .hero p {
            font-size: 1.1rem;
            margin-bottom: 30px;
            opacity: 0.9;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .badge {
            background-color: rgba(249, 115, 22, 0.15);
            color: #ff9800;
            padding: 6px 14px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            margin-bottom: 15px;
            border: 1px solid rgba(249, 115, 22, 0.4);
        }

        /* Indian Problem Focus Services */
        .services {
            padding: 60px 20px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 2rem;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .section-subtitle {
            text-align: center;
            color: #64748b;
            margin-bottom: 45px;
            font-size: 1rem;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
            border: 1px solid #e2e8f0;
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-4px);
        }

        .card-icon {
            font-size: 2.3rem;
            margin-bottom: 15px;
        }

        .card h3 {
            margin-bottom: 12px;
            color: var(--primary);
            font-size: 1.3rem;
        }

        /* Transparent Pricing Section */
        .pricing-section {
            background-color: #ffffff;
            padding: 60px 20px;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            max-width: 1100px;
            margin: 0 auto;
        }

        .price-card {
            background: var(--light-bg);
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 30px;
            text-align: center;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .price-card.featured {
            border: 2.5px solid var(--brand);
            background: white;
            box-shadow: 0 10px 20px -5px rgba(2, 132, 199, 0.1);
        }

        .ribbon {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--success);
            color: white;
            padding: 4px 14px;
            font-size: 0.8rem;
            font-weight: bold;
            border-radius: 20px;
            text-transform: uppercase;
        }

        .price-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .price-amount {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 15px;
        }

        .price-amount span {
            font-size: 1rem;
            color: #64748b;
            font-weight: 400;
        }

        .price-features {
            list-style: none;
            text-align: left;
            margin-bottom: 25px;
            font-size: 0.95rem;
        }

        .price-features li {
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Booking Lead Block */
        .booking-section {
            background-color: #f1f5f9;
            padding: 60px 20px;
        }

        .form-container {
            max-width: 580px;
            margin: 0 auto;
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            color: var(--primary);
            font-size: 0.95rem;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            font-size: 1rem;
            background-color: #fff;
        }

        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.15);
        }

        .submit-btn {
            background-color: var(--brand);
            color: white;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 6px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .submit-btn:hover {
            background-color: #0369a1;
        }

        /* Trust Factors */
        .trust-section {
            padding: 60px 20px;
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
        }

        .trust-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .trust-item h4 {
            color: var(--primary);
            font-size: 1.1rem;
            margin-top: 10px;
            margin-bottom: 5px;
        }

        footer {
            background-color: var(--primary);
            color: #94a3b8;
            text-align: center;
            padding: 25px 20px;
            font-size: 0.85rem;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 1.9rem; }
            .trust-grid { grid-template-columns: 1fr; gap: 25px; }
            .form-container { padding: 20px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="nav-container">
            <div class="logo">🛠️ Suraksha Home Care</div>
            <a href="#book" class="cta-header-btn">Book Now</a>
        </div>
    </header>

    <!-- Value Proposition -->
    <section class="hero">
        <div class="hero-content">
            <span class="badge">Professional Tools • Transparent Fixed Pricing</span>
            <h1>Protect Your Home From Monsoon Damage & Hard-Water Scaling</h1>
            <p>Don't wait for expensive breakdown bills. We clear terrace drainage blocks, deep-flush hard water sediment from your geysers, and seal exterior wall cracks in one professional visit.</p>
            <a href="#book" class="cta-header-btn" style="padding: 14px 28px; font-size: 1.05rem; background-color: var(--accent);">See Rates & Book Plan</a>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services">
        <h2 class="section-title">The Essential Home Protection Services</h2>
        <p class="section-subtitle">Preventing the top structural and electrical failures that trouble Indian homes every year.</p>
        
        <div class="grid">
            <div class="card">
                <div class="card-icon">🌧️</div>
                <h3>Terrace & Balcony Drain Desilting</h3>
                <p>Complete removal of dry leaves, bird droppings, and debris blocking rainwater downspouts. Prevents rainwater pooling that causes immediate ceiling seepage.</p>
            </div>
            <div class="card">
                <div class="card-icon">⚡</div>
                <h3>Geyser & Hard Water Descaling</h3>
                <p>Full tank valve drainage and magnesium scale removal caused by borewell water. Drops electricity bills and increases heating speed immediately.</p>
            </div>
            <div class="card">
                <div class="card-icon">🧱</div>
                <h3>Exterior Crack & Pipeline Sealing</h3>
                <p>Weatherproof caulking around window frames and bathroom outlet pipelines. Stops the main entry points for rain dampness, ants, and pests.</p>
            </div>
        </div>
    </section>

    <!-- NEW: Transparent Pricing Cards Section -->
    <section class="pricing-section" id="pricing">
        <h2 class="section-title">Honest, Fixed Pricing</h2>
        <p class="section-subtitle">No hidden charges. No surprise add-ons post-visit. Select what fits your needs.</p>
        
        <div class="pricing-grid">
            <!-- Individual Item 1 -->
            <div class="price-card">
                <div>
                    <div class="price-title">Pre-Monsoon Drain Clear</div>
                    <div class="price-amount">₹1,499 <span>/ visit</span></div>
                    <ul class="price-features">
                        <li>✅ Up to 4 main balcony/roof drains</li>
                        <li>✅ Debris & sludge vacuuming</li>
                        <li>✅ Downspout pressure flush check</li>
                    </ul>
                </div>
                <a href="#book" class="cta-header-btn" onclick="selectPackage('Pre-Monsoon Drain Clearing Only')" style="background: var(--brand);">Select Plan</a>
            </div>

            <!-- Combo Package (Featured & High Profit) -->
            <div class="price-card featured">
                <div class="ribbon">Best Value Asset Protection</div>
                <div>
                    <div class="price-title" style="margin-top: 10px;">Complete Suraksha Combo</div>
                    <div class="price-amount" style="color: var(--brand);">₹2,999 <span>/ visit</span></div>
                    <ul class="price-features">
                        <li>✅ <strong>All Roof & Balcony Drains Cleared</strong></li>
                        <li>✅ <strong>1x Geyser Deep Chemical Descaling</strong></li>
                        <li>✅ <strong>Exterior Window/Pipe Crack Sealing</strong></li>
                        <li>✅ Before/After Photo Verification Report</li>
                        <li style="color: var(--success); font-weight: bold;">👉 Saves ₹1,000 compared to individual booking!</li>
                    </ul>
                </div>
                <a href="#book" class="cta-header-btn" onclick="selectPackage('Complete Protection Bundle')">Book Combo Pack</a>
            </div>

            <!-- Individual Item 2 -->
            <div class="price-card">
                <div>
                    <div class="price-title">Hard Water Geyser Flush</div>
                    <div class="price-amount">₹1,499 <span>/ appliance</span></div>
                    <ul class="price-features">
                        <li>✅ Heating element scaling cleanup</li>
                        <li>✅ Tank internal rust flush</li>
                        <li>✅ Safety valve function check</li>
                    </ul>
                </div>
                <a href="#book" class="cta-header-btn" onclick="selectPackage('Hard Water Geyser Flush Only')" style="background: var(--brand);">Select Plan</a>
            </div>
        </div>
    </section>

    <!-- Trust Factors -->
    <section class="trust-section">
        <h2>Professional Standards, Transparent Work</h2>
        <div class="trust-grid">
            <div class="trust-item">
                <div style="font-size: 2rem;">🛡️</div>
                <h4>No Middlemen</h4>
                <p>I handle every job personally with proper safety gear. No casual laborers step onto your property.</p>
            </div>
            <div class="trust-item">
                <div style="font-size: 2rem;">📸</div>
                <h4>Before/After Proof</h4>
                <p>Get live photo updates directly on WhatsApp showing you the inside of your pipes and clean heating elements.</p>
            </div>
            <div class="trust-item">
                <div style="font-size: 2rem;">💵</div>
                <h4>Zero Hidden Surcharges</h4>
                <p>The rate you choose is exactly what you pay. Standard parts or extra sealant are discussed transparently.</p>
            </div>
        </div>
    </section>

    <!-- Booking Form -->
    <section class="booking-section" id="book">
        <div class="form-container">
            <h2 style="text-align: center; margin-bottom: 8px; color: var(--primary);">Confirm Your Booking Details</h2>
            <p style="text-align: center; margin-bottom: 25px; color: #64748b; font-size: 0.95rem;">Fill out the details below. It generates a summary message and dispatches it cleanly straight to my WhatsApp.</p>
            
            <form onsubmit="sendToWhatsApp(event)">
                <div class="form-group">
                    <label for="custName">Your Name</label>
                    <input type="text" id="custName" required placeholder="Enter your full name">
                </div>
                
                <div class="form-group">
                    <label for="custPhone">WhatsApp Number</label>
                    <input type="tel" id="custPhone" required placeholder="Enter your 10-digit mobile number">
                </div>

                <div class="form-group">
                    <label for="custLocation">Locality / Area Name</label>
                    <input type="text" id="custLocation" required placeholder="e.g., Kothrud, Bandra West, Gachibowli...">
                </div>

                <div class="form-group">
                    <label for="custService">Select Service Package</label>
                    <select id="custService" onchange="updatePriceDisplay()">
                        <option value="Complete Protection Bundle">Complete Protection Bundle — ₹2,999</option>
                        <option value="Pre-Monsoon Drain Clearing Only">Pre-Monsoon Drain Clearing Only — ₹1,499</option>
                        <option value="Hard Water Geyser Flush Only">Hard Water Geyser Flush Only — ₹1,499</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="custNotes">Additional Property Notes (Optional)</label>
                    <textarea id="custNotes" rows="3" placeholder="e.g., Independent home, 3rd floor apartment, geyser takes too much time to heat..."></textarea>
                </div>

                <button type="submit" class="submit-btn">Send Booking Request via WhatsApp</button>
            </form>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 Suraksha Home Care. Premium Solo Maintenance Specialist. All rights reserved.</p>
    </footer>

    <script>
        // Smoothly auto-select dropdown item if user clicks "Select Plan" button up top
        function selectPackage(val) {
            document.getElementById('custService').value = val;
        }

        function sendToWhatsApp(event) {
            event.preventDefault();
            
            const name = document.getElementById('custName').value;
            const phone = document.getElementById('custPhone').value;
            const location = document.getElementById('custLocation').value;
            const serviceSelect = document.getElementById('custService');
            const selectedText = serviceSelect.options[serviceSelect.selectedIndex].text;
            const notes = document.getElementById('custNotes').value || "None provided";

            // CONFIGURATION: 
            // Put your actual active mobile phone number here (with country code 91, no space, no symbols)
            const businessNumber = "917058853299"; 
            
            const textMessage = `New Service Request Confirmation!%0A%0A` +
                                `*Customer Name:* ${encodeURIComponent(name)}%0A` +
                                `*WhatsApp Contact:* ${encodeURIComponent(phone)}%0A` +
                                `*Locality:* ${encodeURIComponent(location)}%0A` +
                                `*Selected Plan/Price:* ${encodeURIComponent(selectedText)}%0A` +
                                `*Property Notes:* ${encodeURIComponent(notes)}`;
            
            const finalLink = `https://wa.me/${businessNumber}?text=${textMessage}`;
            
            alert("Redirecting! Your custom package booking configuration has been locked in. Click send on WhatsApp to confirm your date with me.");
            window.open(finalLink, '_blank');
        }
    </script>
</body>
</html>
